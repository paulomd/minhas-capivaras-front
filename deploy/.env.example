# Gerado pelo GitHub Actions no deploy automático. Manual: cp .env.example .env
GHCR_IMAGE=ghcr.io/paulomd/minhas-capivaras-front
IMAGE_TAG=latest
FRONTEND_PORT=3000
BACKEND_PORT=8090

APP_PUBLIC_URL=http://SEU_IP_OU_DOMINIO

# URL interna do backend (container → host da VPS onde o backend expõe 8090)
API_URL=http://host.docker.internal:8090
